@page
@model StudentService.Pages.StudentsModel
@{
    // Tắt layout mặc định để dùng code HTML độc lập cho gọn
    Layout = null; 
}

@*
    Trang Razor Page: Quản lý Sinh viên
    - Hiển thị danh sách `Model.StudentList` (lấy từ DB)
    - Form phía trên dùng để Thêm mới / Cập nhật `Model.InputStudent`
    - Các form gửi tới handler trên PageModel: OnPostSave, OnPostDelete, DownloadLogStream
    - Sử dụng `@Html.AntiForgeryToken()` để phòng CSRF
*@

<!DOCTYPE html>
<html>
<head>
    <title>Quản lý Sinh viên - Razor Pages</title>
    <style>
        body { background: #1a1a1a; color: #e0e0e0; font-family: system-ui, sans-serif; padding: 40px; }
        .container { background: #2d2d2d; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
        input { padding: 10px; border-radius: 4px; border: 1px solid #555; background: #3f3f3f; color: #fff; margin-right: 10px; }
        .btn { padding: 10px 20px; border: none; border-radius: 4px; color: #fff; cursor: pointer; font-weight: bold; }
        .btn-save { background: #2e7d32; }
        .btn-edit { background: #1976d2; padding: 6px 12px; }
        .btn-delete { background: #d32f2f; padding: 6px 12px; }
        table { width: 100%; border-collapse: collapse; background: #2d2d2d; }
        th, td { padding: 12px; border-bottom: 1px solid #444; text-align: left; }
        th { background: #3f3f3f; }
    </style>
</head>
<body>
    <h1 style="text-align: center; color: #fff;">Quản lý Hồ sơ Sinh viên</h1>

    <div style="text-align: center; margin-bottom: 20px;">
        <form method="post" action="/Students?handler=DownloadLogStream">
            @Html.AntiForgeryToken()
            <button type="submit" style="background: #ff9800; color: #fff; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
                📥 Tải Lịch sử Log (Test gRPC Streaming)
            </button>
        </form>
    </div>

    <div class="container">
        <form method="post" action="/Students?handler=Save">
            @Html.AntiForgeryToken()
            <input type="hidden" name="InputStudent.Id" value="@Model.InputStudent.Id" />
            <input type="text" name="InputStudent.Name" value="@Model.InputStudent.Name" placeholder="Họ và Tên..." required />
            <input type="email" name="InputStudent.Email" value="@Model.InputStudent.Email" placeholder="Email..." required />
            
            <button type="submit" class="btn btn-save">
                @(Model.InputStudent.Id == 0 ? "Thêm mới" : "Cập nhật")
            </button>
            
            @if(Model.InputStudent.Id != 0)
            {
                <a href="/Students" style="color: #bbb; text-decoration: none; margin-left: 10px;">Hủy sửa</a>
            }
        </form>
    </div>

    <div class="container" style="padding: 0; overflow: hidden;">
        <table>
            <thead>
                <tr>
                    <th>ID</th><th>Họ và Tên</th><th>Email</th><th style="text-align:center;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sv in Model.StudentList)
                {
                    <tr>
                        <td>@sv.Id</td>
                        <td>@sv.Name</td>
                        <td style="color:#90caf9;">@sv.Email</td>
                        <td style="text-align:center;">
                            <a href="/Students?editId=@sv.Id" class="btn btn-edit" style="text-decoration: none; margin-right: 5px;">Sửa</a>
                            
                            <form method="post" action="/Students?handler=Delete&id=@sv.Id" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-delete" onclick="return confirm('Xóa thật không?');">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>