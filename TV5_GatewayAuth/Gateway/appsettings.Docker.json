{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Yarp": "Debug",
            "System.Net.Http": "Debug"
        }
    },
    "ReverseProxy": {
        "Routes": {
            "auth-route": {
                "ClusterId": "auth-cluster",
                "Match": {
                    "Path": "/auth/{**catch-all}"
                }
            },
            "enrollment-route": {
                "ClusterId": "enrollment-grpc-cluster",
                "Match": {
                    "Path": "/EnrollmentService.gRPC.Enrollment/{**catch-all}"
                },
                "AuthorizationPolicy": "RequestVersionExact",
                "Transforms": [
                    {
                        "RequestHeader": "Authorization",
                        "Remove": ""
                    }
                ]
            },
            "student-route": {
                "ClusterId": "student-grpc-cluster",
                "Match": {
                    "Path": "/StudentGrpc/{**catch-all}"
                },
                "AuthorizationPolicy": "DefaultGatewayPolicy"
            },
            "notification-route": {
                "ClusterId": "notification-grpc-cluster",
                "Match": {
                    "Path": "/notify.Notification/{**catch-all}"
                },
                "AuthorizationPolicy": "DefaultGatewayPolicy"
            }
        },

        "Clusters": {
            "auth-cluster": {
                "Destinations": {
                    "dest1": {
                        "Address": "http://auth-service:8080"
                    }
                }
            },
            "enrollment-grpc-cluster": {
                "Destinations": {
                    "dest3": {
                        "Address": "http://enrollment-service:8080"
                    }
                },
                "HttpRequest": {
                    "Version": "2.0",
                    "VersionPolicy": "RequestVersionExact"
                }
            },
            "student-grpc-cluster": {
                "Destinations": {
                    "dest4": {
                        "Address": "http://student-service:8080"
                    }
                },
                "HttpRequest": {
                    "Version": "2.0",
                    "VersionPolicy": "RequestVersionExact"
                }
            },
            "notification-grpc-cluster": {
                "Destinations": {
                    "dest5": {
                        "Address": "http://notification-service:8080"
                    }
                },
                "HttpRequest": {
                    "Version": "2.0",
                    "VersionPolicy": "RequestVersionExact"
                }
            }
        },
        "AllowedHosts": "*"
    }
}