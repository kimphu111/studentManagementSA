{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
    "ReverseProxy": {
        "Routes": {
            "auth-route": {
                "ClusterId": "auth-cluster",
                "Match": {
                    "Path": "/auth/{**catch-all}"
                }
            },

            "student-route": {
                "ClusterId": "student-cluster",
                "Match": {
                    "Path": "/api/student/{**catch-all}"
                }
            },

            "enrollment-route": {
                "ClusterId": "enrollment-cluster",
                "Match": {
                    "Path": "/Enrollment/{**catch-all}"
                }
            },
            "notification-route": {
                "ClusterId": "notification-cluster",
                "Match": {
                    "Path":  "/Notification/{**catch-all}"
                }
            }
        },

        "Clusters": {
            "auth-cluster": {
                "Destinations": {
                    "dest1": {
                        "Address": "http://localhost:5157"
                    }
                }
            },
            "student-cluster": {
                "Destinations": {
                    "dest2": {
                        "Address": "http://localhost:5100"
                    }
                },
                "HttpRequest": {
                    "Version": "2.0",
                    "VersionPolicy": "RequestVersionExact"
                }
            },

            "enrollment-cluster": {
                "Destinations": {
                    "dest3": {
                        "Address": "http://localhost:5273"
                    }
                },
                "HttpRequest": {
                    "Version": "2.0",
                    "VersionPolicy": "RequestVersionExact"
                }
            },
            "notification-cluster": {
                "Destinations": {
                    "dest4": {
                        "Address": "http://localhost5167"
                    }
                },
                "HttpRequest": {
                    "Version": "2.0",
                    "VersionPolicy": "RequestVersionExact"
                }
            }
        }
    },
  "AllowedHosts": "*"
}